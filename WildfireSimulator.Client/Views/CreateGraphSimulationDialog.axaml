<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="620"
        d:DesignHeight="1000"
        x:Class="WildfireSimulator.Client.Views.CreateGraphSimulationDialog"
        Title="Создание графовой симуляции"
        Width="620"
        Height="1000"
        Background="#FAF8F2"
        CanResize="False">

    <Window.Styles>
        <Style Selector="Button.dialogButton">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.dialogButton:pointerover">
            <Setter Property="Opacity" Value="0.88" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto" Margin="20">

        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="14">

               <TextBlock Text="Создание графовой симуляции"
           Foreground="#2F2A3A"
           FontSize="24"
           FontWeight="Bold" />

<Border Background="#F5FBFF"
        BorderBrush="#D7E6F2"
        BorderThickness="1"
        CornerRadius="12"
        Padding="12">
    <StackPanel Spacing="8">
        <TextBlock Text="Быстрые сценарии"
                   FontWeight="Bold"
                   Foreground="#2F2A3A" />

        <TextBlock x:Name="PresetHintTextBlock"
                   Text="Готовые настройки для демонстрации"
                   Foreground="#6E6A78"
                   FontSize="12"
                   TextWrapping="Wrap" />

        <WrapPanel ItemWidth="170"
                   ItemHeight="44">
            <Button x:Name="PresetButton1"
                    Classes="dialogButton"
                    Content="Сценарий 1"
                    Background="#FFE4E1"
                    Margin="0,0,8,8" />

            <Button x:Name="PresetButton2"
                    Classes="dialogButton"
                    Content="Сценарий 2"
                    Background="#E1F0FF"
                    Margin="0,0,8,8" />

            <Button x:Name="PresetButton3"
                    Classes="dialogButton"
                    Content="Сценарий 3"
                    Background="#E6FFE6"
                    Margin="0,0,8,8" />

            <Button x:Name="PresetButton4"
                    Classes="dialogButton"
                    Content="Сценарий 4"
                    Background="#FFF4E1"
                    Margin="0,0,8,8" />

            <Button x:Name="PresetButton5"
                    Classes="dialogButton"
                    Content="Сценарий 5"
                    Background="#F0E6FF"
                    Margin="0,0,8,8" />
        </WrapPanel>
    </StackPanel>
</Border>

                <Border Background="#F3F7FF"
                        BorderBrush="#D7E4FF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Тип модели"
                                   Foreground="#6E6A78"
                                   FontSize="12" />
                        <TextBlock x:Name="TypeInfoTextBlock"
                                   Text="Графовая симуляция"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="TypeHintTextBlock"
                                   Text="Описание выбранного масштаба графа"
                                   Foreground="#6E6A78"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Основные параметры"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <TextBlock Text="Название симуляции"
                                   Foreground="#6E6A78"/>
                        <TextBox x:Name="NameBox"
                                 Watermark="Введите название"/>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock x:Name="WidthLabelTextBlock"
                                           Text="Ширина"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="WidthBox"/>
                                <TextBlock x:Name="WidthHintTextBlock"
                                           Text=""
                                           Foreground="#8E8898"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock x:Name="HeightLabelTextBlock"
                                           Text="Высота"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="HeightBox"/>
                                <TextBlock x:Name="HeightHintTextBlock"
                                           Text=""
                                           Foreground="#8E8898"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Стартовые очаги"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="FireCellsBox"/>
                                <TextBlock x:Name="FireCellsHintTextBlock"
                                           Text=""
                                           Foreground="#8E8898"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Шагов симуляции"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="StepsBox"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Длительность шага (сек)"
                                   Foreground="#6E6A78"/>
                        <TextBox x:Name="StepDurationBox"/>
                    </StackPanel>
                </Border>

               <Border Background="#FFFDF8"
        BorderBrush="#E7E0F2"
        BorderThickness="1"
        CornerRadius="10"
        Padding="12">
    <StackPanel Spacing="10">
        <TextBlock Text="Режим создания графа"
                   Foreground="#2F2A3A"
                   FontSize="16"
                   FontWeight="Bold" />

        <TextBlock Text="Режим"
                   Foreground="#6E6A78"/>
        <ComboBox x:Name="MapCreationModeBox"
                  SelectedIndex="0">
            <ComboBoxItem Content="Случайный"/>
            <ComboBoxItem Content="Сценарий"/>
            <ComboBoxItem Content="Полуручной"/>
        </ComboBox>

        <Border Background="#F8F5FF"
                BorderBrush="#E6DFF1"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <TextBlock x:Name="MapModeDescriptionTextBlock"
                       Text="Описание режима"
                       Foreground="#5F586B"
                       TextWrapping="Wrap"/>
        </Border>

        <StackPanel x:Name="ScenarioPanel"
                    Spacing="8"
                    IsVisible="False">
            <TextBlock Text="Сценарий"
                       Foreground="#6E6A78"/>
            <ComboBox x:Name="ScenarioTypeBox"/>

            <Border Background="#EEF7FF"
                    BorderBrush="#D5E8F7"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <TextBlock x:Name="ScenarioDescriptionTextBlock"
                           Text="Описание сценария"
                           Foreground="#5F586B"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <StackPanel x:Name="SemiManualPanel"
                    Spacing="8"
                    IsVisible="False">
            <Border Background="#F8FCF5"
                    BorderBrush="#D7E8C8"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <TextBlock x:Name="SemiManualDescriptionTextBlock"
                           Text="Описание полуручного режима"
                           Foreground="#5F586B"
                           TextWrapping="Wrap"/>
            </Border>

            <Button x:Name="OpenMapEditorButton"
                    Classes="dialogButton"
                    Content="Открыть редактор структуры графа"
                    Background="#DDEFD5"
                    Foreground="#2F2A3A"/>

            <Border Background="#FFFDF8"
                    BorderBrush="#E7E0F2"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <TextBlock x:Name="MapEditorSummaryTextBlock"
                           Text="Структура графа не задана"
                           Foreground="#5F586B"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </StackPanel>
</Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Параметры карты и среды"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Минимальная влажность"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="MoistureMinBox"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Максимальная влажность"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="MoistureMaxBox"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Variation рельефа"
                                   Foreground="#6E6A78"/>
                        <TextBox x:Name="ElevationBox"/>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Temperature"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="TempBox"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Humidity"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="HumidityBox"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Wind speed"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="WindSpeedBox"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Wind direction"
                                           Foreground="#6E6A78"/>
                                <ComboBox x:Name="WindDirBox"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="North"/>
                                    <ComboBoxItem Content="North-East"/>
                                    <ComboBoxItem Content="East"/>
                                    <ComboBoxItem Content="South-East"/>
                                    <ComboBoxItem Content="South"/>
                                    <ComboBoxItem Content="South-West"/>
                                    <ComboBoxItem Content="West"/>
                                    <ComboBoxItem Content="North-West"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Precipitation"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="PrecipitationBox"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Random seed"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="RandomSeedBox"
                                         Watermark="optional"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Модификаторы генерации"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Map noise strength"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="MapNoiseBox"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Map dryness factor"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="MapDrynessBox"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Relief strength"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="ReliefStrengthBox"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Fuel density factor"
                                           Foreground="#6E6A78"/>
                                <TextBox x:Name="FuelDensityBox"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Распределение растительности"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Coniferous" Foreground="#6E6A78"/>
                                    <TextBox x:Name="ConiferousBox"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Deciduous" Foreground="#6E6A78"/>
                                    <TextBox x:Name="DeciduousBox"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Mixed" Foreground="#6E6A78"/>
                                    <TextBox x:Name="MixedBox"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Grass" Foreground="#6E6A78"/>
                                    <TextBox x:Name="GrassBox"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="6">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Shrub" Foreground="#6E6A78"/>
                                    <TextBox x:Name="ShrubBox"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Water" Foreground="#6E6A78"/>
                                    <TextBox x:Name="WaterBox"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Bare" Foreground="#6E6A78"/>
                                    <TextBox x:Name="BareBox"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#F8F6FB"
                        BorderBrush="#E2DCEC"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Предпросмотр структуры"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <TextBlock x:Name="StructureSummaryTextBlock"
                                   Text="Summary"
                                   Foreground="#564F64"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="StructureDetailTextBlock"
                                   Text="Details"
                                   Foreground="#6C6678"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="ErrorTextBlock"
                           Text=""
                           Foreground="#C62828"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,14,0,0">
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="10">
                <Button x:Name="CancelButton"
                        Grid.Column="0"
                        Classes="dialogButton"
                        Content="Отмена"
                        Background="#E7E1D8"
                        Foreground="#2F2A3A"/>

                <Button x:Name="CreateButton"
                        Grid.Column="1"
                        Classes="dialogButton"
                        Content="Создать симуляцию"
                        Background="#8E7CC3"
                        Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</Window>