<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="620"
        d:DesignHeight="1000"
        x:Class="WildfireSimulator.Client.Views.CreateGraphSimulationDialog"
        Title="Создание графовой симуляции"
        Width="620"
        Height="1000"
        Background="#FAF8F2"
        CanResize="False">

    <Window.Styles>
        <Style Selector="Button.dialogButton">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.dialogButton:pointerover">
            <Setter Property="Opacity" Value="0.88" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto" Margin="20">
        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="14">

                <TextBlock Text="Создание графовой симуляции"
                           Foreground="#2F2A3A"
                           FontSize="24"
                           FontWeight="Bold" />

                <Border Background="#F5FBFF"
                        BorderBrush="#D7E6F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Демо графовой модели"
                                   FontWeight="Bold"
                                   Foreground="#2F2A3A" />

                        <TextBlock x:Name="PresetHintTextBlock"
                                   Text="Выберите готовое демо для графа"
                                   Foreground="#6E6A78"
                                   FontSize="12"
                                   TextWrapping="Wrap" />

                        <WrapPanel>
                            <Button x:Name="PresetButton1"
                                    Classes="dialogButton"
                                    Content="Сухой хвойный массив"
                                    Tag="dry"
                                    Background="#FFE4E1"
                                    Margin="0,0,8,8" />

                            <Button x:Name="PresetButton2"
                                    Classes="dialogButton"
                                    Content="Водный барьер"
                                    Tag="water"
                                    Background="#E1F0FF"
                                    Margin="0,0,8,8" />

                            <Button x:Name="PresetButton3"
                                    Classes="dialogButton"
                                    Content="Просека"
                                    Tag="firebreak"
                                    Background="#FFF4E1"
                                    Margin="0,0,8,8" />

                            <Button x:Name="PresetButton4"
                                    Classes="dialogButton"
                                    Content="Холмистые зоны"
                                    Tag="hills"
                                    Background="#F0E6FF"
                                    Margin="0,0,8,8" />

                            <Button x:Name="PresetButton5"
                                    Classes="dialogButton"
                                    Content="Смешанный лес"
                                    Tag="mixed"
                                    Background="#EEF6E6"
                                    Margin="0,0,8,8" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Background="#F3F7FF"
                        BorderBrush="#D7E4FF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Тип модели"
                                   Foreground="#6E6A78"
                                   FontSize="12" />
                        <TextBlock x:Name="TypeInfoTextBlock"
                                   Text="Графовая симуляция"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="TypeHintTextBlock"
                                   Text="Выберите демо графа и настройте параметры среды."
                                   Foreground="#6E6A78"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="#FFF4F1"
                        BorderBrush="#F1C4BA"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12"
                        IsVisible="False">
                    <TextBlock x:Name="ErrorTextBlock"
                               Text=""
                               Foreground="#B5473E"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Основные параметры"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Название"
                                       Foreground="#6E6A78" />
                            <TextBox x:Name="NameBox"
                                     Text="Графовая симуляция" />
                            <TextBlock Text="Свободное название симуляции."
                                       Foreground="#8A8793"
                                       FontSize="11" />
                        </StackPanel>

        

                        <StackPanel Spacing="4">
                            <TextBlock Text="Начальные очаги"
                                       Foreground="#6E6A78" />
                            <TextBox x:Name="FireCellsBox"
                                     Text="2" />
                            <TextBlock x:Name="FireCellsHintTextBlock"
                                       Text="Число стартовых очагов при случайном запуске."
                                       Foreground="#8A8793"
                                       FontSize="11" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Количество шагов"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="StepsBox"
                                         Text="100" />
                                <TextBlock Text="Диапазон: 1..10000"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Длительность шага, сек"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="StepDurationBox"
                                         Text="900" />
                                <TextBlock Text="Диапазон: 1..7200"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Параметры среды"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Минимальная влажность"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="MoistureMinBox"
                                         Text="0.24" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Максимальная влажность"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="MoistureMaxBox"
                                         Text="0.62" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Перепад высот"
                                       Foreground="#6E6A78" />
                            <TextBox x:Name="ElevationBox"
                                     Text="55" />
                            <TextBlock Text="Рекомендуемый диапазон: 0..500"
                                       Foreground="#8A8793"
                                       FontSize="11" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Температура воздуха"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="TempBox"
                                         Text="26" />
                                <TextBlock Text="Рекомендуемый диапазон: -50..60"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Влажность воздуха"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="HumidityBox"
                                         Text="38" />
                                <TextBlock Text="Диапазон: 0..100"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Скорость ветра"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="WindSpeedBox"
                                         Text="5" />
                                <TextBlock Text="Рекомендуемый диапазон: 0..40"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Направление ветра"
                                           Foreground="#6E6A78" />
                                <ComboBox x:Name="WindDirBox"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="Север" />
                                    <ComboBoxItem Content="Северо-восток" />
                                    <ComboBoxItem Content="Восток" />
                                    <ComboBoxItem Content="Юго-восток" />
                                    <ComboBoxItem Content="Юг" />
                                    <ComboBoxItem Content="Юго-запад" />
                                    <ComboBoxItem Content="Запад" />
                                    <ComboBoxItem Content="Северо-запад" />
                                </ComboBox>
                                <TextBlock Text="Выберите одно из направлений."
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Осадки"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="PrecipitationBox"
                                         Text="0" />
                                <TextBlock Text="Рекомендуемый диапазон: 0..100"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Случайное зерно"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="RandomSeedBox"
                                         Text="" />
                                <TextBlock Text="Целое число или пусто для случайной генерации."
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Расширенные параметры графа"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Шум размещения"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="MapNoiseBox"
                                         Text="0.08" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Фактор сухости"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="MapDrynessBox"
                                         Text="1.0" />
                                <TextBlock Text="Рекомендуемый диапазон: 0.5..2.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Выраженность рельефа"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="ReliefStrengthBox"
                                         Text="1.0" />
                                <TextBlock Text="Рекомендуемый диапазон: 0.5..2.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Плотность топлива"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="FuelDensityBox"
                                         Text="1.0" />
                                <TextBlock Text="Рекомендуемый диапазон: 0.5..2.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Распределение типов поверхности"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Хвойный лес"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="ConiferousBox"
                                         Text="0.24" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Лиственный лес"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="DeciduousBox"
                                         Text="0.18" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Смешанный лес"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="MixedBox"
                                         Text="0.28" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Трава"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="GrassBox"
                                         Text="0.12" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Кустарник"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="ShrubBox"
                                         Text="0.10" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Вода"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="WaterBox"
                                         Text="0.04" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Пустая поверхность"
                                       Foreground="#6E6A78" />
                            <TextBox x:Name="BareBox"
                                     Text="0.04" />
                            <TextBlock Text="Значения используются для случайного графа и отдельных демо. Сумма будет нормализована автоматически."
                                       Foreground="#8A8793"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#F8F5FF"
                        BorderBrush="#E6DFF1"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Описание выбранного демо"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <TextBlock x:Name="MapModeDescriptionTextBlock"
                                   Text="Граф создаётся по выбранному демо."
                                   Foreground="#6E6A78"
                                   TextWrapping="Wrap" />

                        <TextBlock x:Name="ScenarioDescriptionTextBlock"
                                   Text="Описание сценария будет обновлено после выбора демо."
                                   Foreground="#6E6A78"
                                   TextWrapping="Wrap" />

                        <TextBlock x:Name="MapEditorSummaryTextBlock"
                                   Text="Редактор итогового графа будет доработан отдельно."
                                   Foreground="#8A8793"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="#F6FBF6"
                        BorderBrush="#D9E8D9"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="StructureSummaryTextBlock"
                                   Text="Структура графа"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <TextBlock x:Name="StructureDetailTextBlock"
                                   Text="Описание структуры графа."
                                   Foreground="#6E6A78"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ComboBox x:Name="MapCreationModeBox"
                          IsVisible="False" />

                <ComboBox x:Name="ScenarioTypeBox"
                          IsVisible="False" />

                <StackPanel x:Name="ScenarioPanel"
                            IsVisible="False" />

                <StackPanel x:Name="SemiManualPanel"
                            IsVisible="False" />

                <TextBlock x:Name="SemiManualDescriptionTextBlock"
                           IsVisible="False" />

                <Button x:Name="OpenMapEditorButton"
                        IsVisible="False" />

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="10"
              Margin="0,14,0,0">
            <Button x:Name="CancelButton"
                    Grid.Column="0"
                    Classes="dialogButton"
                    Content="Отмена"
                    Background="#E7E1D8"
                    Foreground="#2F2A3A" />

            <Button x:Name="CreateButton"
                    Grid.Column="1"
                    Classes="dialogButton"
                    Content="Создать"
                    Background="#8E7CC3"
                    Foreground="White" />
        </Grid>
    </Grid>
</Window>