<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="1080"
    x:Class="WildfireSimulator.Client.Views.CreateSimulationDialog"
    Title="Создание новой симуляции"
    Width="620"
    Height="1080"
    Background="#FAF8F2"
    CanResize="False">

    <Window.Styles>
        <Style Selector="Button.dialogButton">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.dialogButton:pointerover">
            <Setter Property="Opacity" Value="0.88" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto" Margin="20">

        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="14">

                <TextBlock Text="Создание симуляции"
                    Foreground="#2F2A3A"
                    FontSize="24"
                    FontWeight="Bold" />

                <Border Background="#F3F7FF"
                    BorderBrush="#D7E4FF"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Тип модели"
                            Foreground="#6E6A78"
                            FontSize="12" />
                        <TextBlock x:Name="TypeInfoTextBlock"
                            Text="Сеточная симуляция"
                            Foreground="#2F2A3A"
                            FontSize="16"
                            FontWeight="Bold" />
                        <TextBlock x:Name="TypeHintTextBlock"
                            Text="Введите параметры и создайте модель."
                            Foreground="#6E6A78"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="#FFF4F1"
                    BorderBrush="#F1C4BA"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    IsVisible="True">
                    <TextBlock x:Name="ErrorTextBlock"
                        Text=""
                        Foreground="#B5473E"
                        FontWeight="SemiBold"
                        TextWrapping="Wrap" />
                </Border>

                <Border Background="#F7F5FF"
                    BorderBrush="#DDD5F1"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Режим создания карты"
                            Foreground="#2F2A3A"
                            FontSize="16"
                            FontWeight="Bold" />

                        <StackPanel>
                            <TextBlock Text="Способ подготовки карты"
                                Foreground="#6E6A78"
                                Margin="0,0,0,6" />
                            <ComboBox x:Name="MapCreationModeBox"
                                SelectedIndex="0">
                                <ComboBoxItem Content="Случайная генерация" />
                                <ComboBoxItem Content="Сценарий" />
                                <ComboBoxItem Content="Полуручное создание" />
                            </ComboBox>
                        </StackPanel>

                        <Border Background="#FFFDF8"
                            BorderBrush="#E7E0F2"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Описание режима"
                                    Foreground="#2F2A3A"
                                    FontWeight="Bold" />
                                <TextBlock x:Name="MapModeDescriptionTextBlock"
                                    Text="Карта будет сформирована автоматически по текущим параметрам и распределениям."
                                    Foreground="#5E5870"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <StackPanel x:Name="ScenarioPanel"
                            Spacing="8"
                            IsVisible="False">
                            <TextBlock Text="Сценарий карты"
                                Foreground="#2F2A3A"
                                FontWeight="Bold" />

                            <StackPanel>
                                <TextBlock Text="Выберите готовый сценарий"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <ComboBox x:Name="ScenarioTypeBox"
                                    SelectedIndex="0">
                                    <ComboBoxItem Content="Смешанный лес" />
                                    <ComboBoxItem Content="Сухой хвойный массив" />
                                    <ComboBoxItem Content="Лес с рекой" />
                                    <ComboBoxItem Content="Лес с озером" />
                                    <ComboBoxItem Content="Лес с просекой" />
                                    <ComboBoxItem Content="Холмистая местность" />
                                    <ComboBoxItem Content="Влажный лес после дождя" />
                                </ComboBox>
                            </StackPanel>

                            <Border Background="#F8FCF5"
                                BorderBrush="#D7E8C8"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Описание сценария"
                                        Foreground="#2F2A3A"
                                        FontWeight="Bold" />
                                    <TextBlock x:Name="ScenarioDescriptionTextBlock"
                                        Text="Сбалансированный лесной ландшафт с несколькими типами растительности."
                                        Foreground="#5E5870"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="SemiManualPanel"
                            Spacing="8"
                            IsVisible="False">
                            <TextBlock Text="Полуручное создание"
                                Foreground="#2F2A3A"
                                FontWeight="Bold" />
                            <Border Background="#FFF8EF"
                                BorderBrush="#ECD8B8"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SemiManualDescriptionTextBlock"
                                        Text="Используйте редактор областей, чтобы задать крупные элементы карты до запуска симуляции."
                                        Foreground="#6A5A44"
                                        TextWrapping="Wrap" />

                                    <TextBlock x:Name="MapEditorSummaryTextBlock"
                                        Text="Редактор ещё не использовался."
                                        Foreground="#7A6A56"
                                        FontSize="12"
                                        TextWrapping="Wrap" />

                                    <Button x:Name="OpenMapEditorButton"
                                        Content="Открыть редактор карты"
                                        Background="#EFD9B5"
                                        Foreground="#2F2A3A"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <StackPanel>
                                <TextBlock Text="Сила локальной неоднородности"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="MapNoiseBox"
                                    Text="0.08"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                                <TextBlock
                                    Text="Обычно от 0.00 до 0.20. Чем больше значение, тем сильнее локальный шум."
                                    Foreground="#9A96A3"
                                    FontSize="11"
                                    Margin="0,4,0,0"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Background="#F8FCF5"
                                BorderBrush="#D7E8C8"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Макропараметры карты"
                                        Foreground="#2F2A3A"
                                        FontWeight="Bold" />

                                    <Grid ColumnDefinitions="*,*"
                                        ColumnSpacing="12">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Общая сухость карты"
                                                Foreground="#6E6A78"
                                                Margin="0,0,0,6" />
                                            <TextBox x:Name="MapDrynessBox"
                                                Text="1.0"
                                                Background="#FAF8F2"
                                                Foreground="#2F2A3A" />
                                            <TextBlock
                                                Text="0.5–1.5. Больше — суше карта и быстрее распространение."
                                                Foreground="#9A96A3"
                                                FontSize="11"
                                                Margin="0,4,0,0"
                                                TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Сила рельефа"
                                                Foreground="#6E6A78"
                                                Margin="0,0,0,6" />
                                            <TextBox x:Name="ReliefStrengthBox"
                                                Text="1.0"
                                                Background="#FAF8F2"
                                                Foreground="#2F2A3A" />
                                            <TextBlock
                                                Text="0.5–1.5. Больше — сильнее перепады высот."
                                                Foreground="#9A96A3"
                                                FontSize="11"
                                                Margin="0,4,0,0"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel>
                                        <TextBlock Text="Плотность горючего покрова"
                                            Foreground="#6E6A78"
                                            Margin="0,0,0,6" />
                                        <TextBox x:Name="FuelDensityBox"
                                            Text="1.0"
                                            Background="#FAF8F2"
                                            Foreground="#2F2A3A" />
                                        <TextBlock
                                            Text="0.5–1.5. Больше — чаще тяжёлые типы растительности."
                                            Foreground="#9A96A3"
                                            FontSize="11"
                                            Margin="0,4,0,0"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>


                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                    BorderBrush="#E7E0F2"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Основные параметры"
                            Foreground="#2F2A3A"
                            FontSize="16"
                            FontWeight="Bold" />

                        <StackPanel>
                            <TextBlock Text="Название симуляции"
                                Foreground="#6E6A78"
                                Margin="0,0,0,6" />
                            <TextBox x:Name="NameBox"
                                Text="Моя симуляция"
                                Background="#FAF8F2"
                                Foreground="#2F2A3A" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12">
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="WidthLabelTextBlock"
                                    Text="Ширина"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="WidthBox"
                                    Text="20"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                                <TextBlock x:Name="WidthHintTextBlock"
                                    Text="Минимум 5, максимум 100."
                                    Foreground="#9A96A3"
                                    FontSize="11"
                                    Margin="0,4,0,0"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="HeightLabelTextBlock"
                                    Text="Высота"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="HeightBox"
                                    Text="20"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                                <TextBlock x:Name="HeightHintTextBlock"
                                    Text="Минимум 5, максимум 100."
                                    Foreground="#9A96A3"
                                    FontSize="11"
                                    Margin="0,4,0,0"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Border Background="#F8F5FF"
                            BorderBrush="#E6DFF1"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Структура модели"
                                    Foreground="#2F2A3A"
                                    FontWeight="Bold" />
                                <TextBlock x:Name="StructureSummaryTextBlock"
                                    Text="Сетка 20×20 = 400 клеток."
                                    Foreground="#5E5870"
                                    TextWrapping="Wrap" />
                                <TextBlock x:Name="StructureDetailTextBlock"
                                    Text="Параметры автоматически учитываются при построении модели."
                                    Foreground="#8B8596"
                                    FontSize="11"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <StackPanel>
                            <TextBlock Text="Количество начальных очагов"
                                Foreground="#6E6A78"
                                Margin="0,0,0,6" />
                            <TextBox x:Name="FireCellsBox"
                                Text="3"
                                Background="#FAF8F2"
                                Foreground="#2F2A3A" />
                            <TextBlock x:Name="FireCellsHintTextBlock"
                                Text="Минимум 1."
                                Foreground="#9A96A3"
                                FontSize="11"
                                Margin="0,4,0,0"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#F2FAEA"
                    BorderBrush="#D7E8C8"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Параметры среды"
                            Foreground="#2F2A3A"
                            FontSize="16"
                            FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Минимальная влажность топлива"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="MoistureMinBox"
                                    Text="0.3"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                                <TextBlock Text="От 0.0 до 1.0"
                                    Foreground="#9A96A3"
                                    FontSize="11"
                                    Margin="0,4,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Максимальная влажность топлива"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="MoistureMaxBox"
                                    Text="0.7"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                                <TextBlock Text="От 0.0 до 1.0"
                                    Foreground="#9A96A3"
                                    FontSize="11"
                                    Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Вариация рельефа"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="ElevationBox"
                                    Text="50"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Количество шагов"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="StepsBox"
                                    Text="100"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Длительность шага (сек.)"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="StepDurationBox"
                                    Text="900"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Seed (необязательно)"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="RandomSeedBox"
                                    Text=""
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#F5FBFF"
                    BorderBrush="#D7E6F2"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Погода"
                            Foreground="#2F2A3A"
                            FontSize="16"
                            FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Температура"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="TempBox"
                                    Text="25"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Влажность воздуха"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="HumidityBox"
                                    Text="40"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Скорость ветра"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="WindSpeedBox"
                                    Text="5"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Направление ветра"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <ComboBox x:Name="WindDirBox">
                                    <ComboBoxItem Content="Север" />
                                    <ComboBoxItem Content="Северо-восток" />
                                    <ComboBoxItem Content="Восток" />
                                    <ComboBoxItem Content="Юго-восток" />
                                    <ComboBoxItem Content="Юг" />
                                    <ComboBoxItem Content="Юго-запад" />
                                    <ComboBoxItem Content="Запад" />
                                    <ComboBoxItem Content="Северо-запад" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock Text="Осадки"
                                Foreground="#6E6A78"
                                Margin="0,0,0,6" />
                            <TextBox x:Name="PrecipitationBox"
                                Text="0"
                                Background="#FAF8F2"
                                Foreground="#2F2A3A" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                    BorderBrush="#E7E0F2"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Распределение растительности"
                            Foreground="#2F2A3A"
                            FontSize="16"
                            FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="12"
                            RowDefinitions="Auto,Auto,Auto,Auto">

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Хвойный лес"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="ConiferousBox"
                                    Text="30"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1">
                                <TextBlock Text="Лиственный лес"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="DeciduousBox"
                                    Text="20"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="Смешанный лес"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="MixedBox"
                                    Text="25"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="Трава"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="GrassBox"
                                    Text="15"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Кустарник"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="ShrubBox"
                                    Text="10"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1">
                                <TextBlock Text="Вода"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="WaterBox"
                                    Text="0"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0">
                                <TextBlock Text="Пустая поверхность"
                                    Foreground="#6E6A78"
                                    Margin="0,0,0,6" />
                                <TextBox x:Name="BareBox"
                                    Text="0"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
            Background="#FFFDF8"
            BorderBrush="#E7E0F2"
            BorderThickness="1"
            CornerRadius="12"
            Padding="12"
            Margin="0,14,0,0">
            <Grid ColumnDefinitions="*,*"
                ColumnSpacing="10">
                <Button Grid.Column="0"
                    x:Name="CancelButton"
                    Classes="dialogButton"
                    Content="Отмена"
                    Background="#ECE6FA"
                    Foreground="#2F2A3A" />

                <Button Grid.Column="1"
                    x:Name="CreateButton"
                    Classes="dialogButton"
                    Content="Создать симуляцию"
                    Background="#B7E4A8"
                    Foreground="#2F2A3A"
                    FontWeight="Bold" />
            </Grid>
        </Border>
    </Grid>
</Window>