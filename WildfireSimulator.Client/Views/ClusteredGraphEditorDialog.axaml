<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="WildfireSimulator.Client.Views.ClusteredGraphEditorDialog"
        Title="Редактор кластерного графа"
        Width="1360"
        Height="860"
        MinWidth="1200"
        MinHeight="760"
        Background="#FAF8F2">

    <Grid ColumnDefinitions="390,*" RowDefinitions="*,Auto" Margin="16">

        <Border Grid.Column="0"
                Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,12,0">
            <ScrollViewer>
                <StackPanel Spacing="12">

                    <TextBlock Text="Редактор кластерного графа"
                               Foreground="#2F2A3A"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <TextBlock Text="Создавайте узлы, задавайте их свойства, соединяйте рёбрами и настраивайте структуру graph blueprint."
                               Foreground="#6E6A78"
                               TextWrapping="Wrap"/>

                    <Border Background="#F8F5FF"
                            BorderBrush="#E6DFF1"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Режим редактирования"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>
                            <ComboBox x:Name="ModeBox"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Выбор и создание узлов"/>
                                <ComboBoxItem Content="Создание рёбер"/>
                                <ComboBoxItem Content="Удаление рёбер"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Background="#F8FCF5"
                            BorderBrush="#D7E8C8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Кандидатные точки"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Количество точек-кандидатов"
                                       Foreground="#6E6A78"/>
                            <TextBox x:Name="CandidateCountBox"
                                     Text="90"/>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <Button x:Name="RegenerateCandidatesButton"
                                        Grid.Column="0"
                                        Content="Перегенерировать"
                                        Background="#E7E1D8"
                                        Foreground="#2F2A3A"/>

                                <Button x:Name="AutoConnectButton"
                                        Grid.Column="1"
                                        Content="Автосвязать"
                                        Background="#DDEFD5"
                                        Foreground="#2F2A3A"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8EE"
                            BorderBrush="#EFD9B9"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Автогруппировка и нормализация"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Количество групп"
                                       Foreground="#6E6A78"/>
                            <TextBox x:Name="AutoGroupCountBox"
                                     Text="4"/>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <Button x:Name="AutoGroupButton"
                                        Grid.Column="0"
                                        Content="Разбить на группы"
                                        Background="#E7E1D8"
                                        Foreground="#2F2A3A"/>

                                <Button x:Name="NormalizeEdgesButton"
                                        Grid.Column="1"
                                        Content="Нормализовать рёбра"
                                        Background="#E7E1D8"
                                        Foreground="#2F2A3A"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <Button x:Name="WeakenBridgesButton"
                                        Grid.Column="0"
                                        Content="Ослабить мосты"
                                        Background="#F8E6D9"
                                        Foreground="#2F2A3A"/>

                                <Button x:Name="BoostLocalEdgesButton"
                                        Grid.Column="1"
                                        Content="Усилить локальные"
                                        Background="#E2F0FF"
                                        Foreground="#2F2A3A"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#F6FAFF"
                            BorderBrush="#D6E6F8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Свойства узла"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="SelectedNodeSummaryTextBlock"
                                       Text="Узел не выбран"
                                       Foreground="#5E5A69"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Cluster ID"
                                       Foreground="#6E6A78"/>
                            <TextBox x:Name="NodeClusterIdBox"
                                     Text="patch-manual-1"/>

                            <TextBlock Text="Растительность"
                                       Foreground="#6E6A78"/>
                            <ComboBox x:Name="NodeVegetationBox"
                                      SelectedIndex="4">
                                <ComboBoxItem Content="Трава"/>
                                <ComboBoxItem Content="Кустарник"/>
                                <ComboBoxItem Content="Лиственный лес"/>
                                <ComboBoxItem Content="Хвойный лес"/>
                                <ComboBoxItem Content="Смешанный лес"/>
                                <ComboBoxItem Content="Вода"/>
                                <ComboBoxItem Content="Пустая поверхность"/>
                            </ComboBox>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <StackPanel Grid.Column="0"
                                            Spacing="4">
                                    <TextBlock Text="Влажность"
                                               Foreground="#6E6A78"/>
                                    <TextBox x:Name="NodeMoistureBox"
                                             Text="0.45"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Spacing="4">
                                    <TextBlock Text="Высота"
                                               Foreground="#6E6A78"/>
                                    <TextBox x:Name="NodeElevationBox"
                                             Text="0"/>
                                </StackPanel>
                            </Grid>

                            <Button x:Name="ApplyNodeButton"
                                    Content="Применить к узлу"
                                    Background="#DDEFD5"
                                    Foreground="#2F2A3A"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF9F3"
                            BorderBrush="#E8D9C8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Свойства ребра"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="SelectedEdgeSummaryTextBlock"
                                       Text="Ребро не выбрано"
                                       Foreground="#5E5A69"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Distance override"
                                       Foreground="#6E6A78"/>
                            <TextBox x:Name="EdgeDistanceBox"
                                     Watermark="auto"/>

                            <TextBlock Text="FireSpreadModifier"
                                       Foreground="#6E6A78"/>
                            <TextBox x:Name="EdgeModifierBox"
                                     Text="1.00"/>

                            <Button x:Name="ApplyEdgeButton"
                                    Content="Применить к ребру"
                                    Background="#E7E1D8"
                                    Foreground="#2F2A3A"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F8F6FB"
                            BorderBrush="#E2DCEC"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Сводка"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="SummaryTextBlock"
                                       Text="Узлов: 0 • рёбер: 0 • групп: 0 • мостов: 0 • изолированных: 0"
                                       Foreground="#564F64"
                                       TextWrapping="Wrap"/>

                            <Border Background="#FFFDF8"
                                    BorderBrush="#E9E2F0"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8">
                                <TextBlock x:Name="HintTextBlock"
                                           Text="Подсказки редактора будут отображаться здесь."
                                           Foreground="#6B6476"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="10">

                <Border Grid.Row="0"
                        Background="#F7F3FF"
                        BorderBrush="#E4DAF0"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10">
                    <TextBlock Text="Canvas blueprint • ЛКМ по пустому месту создаёт узел • ПКМ по узлу удаляет его • в режиме рёбер выбирайте два узла подряд"
                               Foreground="#5F586B"
                               TextWrapping="Wrap"/>
                </Border>

                <ScrollViewer Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <Canvas x:Name="GraphCanvas"
                            Width="920"
                            Height="760"
                            Background="#FBF9F4"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="1"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12"
                Margin="0,12,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="После сохранения blueprint будет использован как source of truth для semi-manual clustered graph."
                           VerticalAlignment="Center"
                           Foreground="#5F586B"
                           TextWrapping="Wrap"/>

                <Button x:Name="CancelButton"
                        Grid.Column="1"
                        Content="Отмена"
                        MinWidth="130"
                        Height="42"
                        Background="#E7E1D8"
                        Foreground="#2F2A3A"/>

                <Button x:Name="ApplyButton"
                        Grid.Column="2"
                        Content="Сохранить blueprint"
                        MinWidth="190"
                        Height="42"
                        Background="#8E7CC3"
                        Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</Window>