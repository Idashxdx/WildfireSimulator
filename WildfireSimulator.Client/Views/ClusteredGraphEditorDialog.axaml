<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WildfireSimulator.Client.Views.ClusteredGraphEditorDialog"
        Title="Редактор итогового графа"
        Width="1360"
        Height="860"
        MinWidth="1180"
        MinHeight="740"
        Background="#FAF8F2">

    <Window.Styles>
        <Style Selector="Button.editorButton">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.editorButton:pointerover">
            <Setter Property="Opacity" Value="0.88" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="390,*" RowDefinitions="*,Auto" Margin="16">

        <Border Grid.Column="0"
                Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,12,0">

            <ScrollViewer>
                <StackPanel Spacing="12">

                    <TextBlock Text="Редактор итогового графа"
                               Foreground="#2F2A3A"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <TextBlock Text="Здесь можно собрать итоговую структуру большого графа: области, вершины и мосты между ними."
                               Foreground="#6E6A78"
                               TextWrapping="Wrap"/>

                    <Border Background="#F8F5FF"
                            BorderBrush="#E6DFF1"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Режим работы"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <ComboBox x:Name="ModeBox"
          SelectedIndex="0">
    <ComboBoxItem Content="Выбор и перемещение"/>
    <ComboBoxItem Content="Добавление вершин"/>
    <ComboBoxItem Content="Создание рёбер"/>
    <ComboBoxItem Content="Создание мостов"/>
    <ComboBoxItem Content="Удаление рёбер"/>
</ComboBox>
                            <TextBlock x:Name="HintTextBlock"
                                       Text="ЛКМ по вершине — выбрать, перетаскивание — переместить."
                                       Foreground="#6E6A78"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F5FBFF"
                            BorderBrush="#D7E6F2"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Области"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Текущая область"
                                       Foreground="#6E6A78"/>

                            <ComboBox x:Name="AreaBox"/>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <Button x:Name="AddAreaButton"
                                        Grid.Column="0"
                                        Classes="editorButton"
                                        Content="Добавить"
                                        Background="#DDEFD5"
                                        Foreground="#2F2A3A"/>

                                <Button x:Name="DeleteAreaButton"
                                        Grid.Column="1"
                                        Classes="editorButton"
                                        Content="Удалить"
                                        Background="#FFE1DD"
                                        Foreground="#2F2A3A"/>
                            </Grid>

                            <TextBlock Text="Название области"
                                       Foreground="#6E6A78"/>

                            <TextBox x:Name="AreaNameBox"/>

                            <TextBlock Text="Растительность области"
                                       Foreground="#6E6A78"/>

                            <ComboBox x:Name="AreaVegetationBox">
                                <ComboBoxItem Content="Трава"/>
                                <ComboBoxItem Content="Кустарник"/>
                                <ComboBoxItem Content="Лиственный лес"/>
                                <ComboBoxItem Content="Хвойный лес"/>
                                <ComboBoxItem Content="Смешанный лес"/>
                                <ComboBoxItem Content="Вода"/>
                                <ComboBoxItem Content="Пустая поверхность"/>
                            </ComboBox>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Влажность"
                                               Foreground="#6E6A78"/>
                                    <TextBox x:Name="AreaMoistureBox"
                                             Text="0.45"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Высота"
                                               Foreground="#6E6A78"/>
                                    <TextBox x:Name="AreaElevationBox"
                                             Text="0"/>
                                </StackPanel>
                            </Grid>

                            <Button x:Name="ApplyAreaButton"
                                    Classes="editorButton"
                                    Content="Применить к узлам области"
                                    Background="#E7E1D8"
                                    Foreground="#2F2A3A"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF7ED"
                            BorderBrush="#F0DDC2"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Выбранная вершина"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="SelectedNodeSummaryTextBlock"
                                       Text="Вершина не выбрана."
                                       Foreground="#6A5A44"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Область вершины"
                                       Foreground="#6E6A78"/>
                            <TextBox x:Name="NodeClusterIdBox"/>

                            <TextBlock Text="Растительность"
                                       Foreground="#6E6A78"/>
                            <ComboBox x:Name="NodeVegetationBox">
                                <ComboBoxItem Content="Трава"/>
                                <ComboBoxItem Content="Кустарник"/>
                                <ComboBoxItem Content="Лиственный лес"/>
                                <ComboBoxItem Content="Хвойный лес"/>
                                <ComboBoxItem Content="Смешанный лес"/>
                                <ComboBoxItem Content="Вода"/>
                                <ComboBoxItem Content="Пустая поверхность"/>
                            </ComboBox>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Влажность"
                                               Foreground="#6E6A78"/>
                                    <TextBox x:Name="NodeMoistureBox"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Высота"
                                               Foreground="#6E6A78"/>
                                    <TextBox x:Name="NodeElevationBox"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <Button x:Name="ApplyNodeButton"
                                        Grid.Column="0"
                                        Classes="editorButton"
                                        Content="Применить"
                                        Background="#DDEFD5"
                                        Foreground="#2F2A3A"/>

                                <Button x:Name="DeleteNodeButton"
                                        Grid.Column="1"
                                        Classes="editorButton"
                                        Content="Удалить"
                                        Background="#FFE1DD"
                                        Foreground="#2F2A3A"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#F8F5FF"
                            BorderBrush="#E6DFF1"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Выбранное ребро"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="SelectedEdgeSummaryTextBlock"
                                       Text="Ребро не выбрано."
                                       Foreground="#6A5A44"
                                       TextWrapping="Wrap"/>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Расстояние"
                                               Foreground="#6E6A78"/>
                                    <TextBox x:Name="EdgeDistanceBox"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Коэффициент"
                                               Foreground="#6E6A78"/>
                                    <TextBox x:Name="EdgeModifierBox"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <Button x:Name="ApplyEdgeButton"
                                        Grid.Column="0"
                                        Classes="editorButton"
                                        Content="Применить"
                                        Background="#DDEFD5"
                                        Foreground="#2F2A3A"/>

                                <Button x:Name="DeleteEdgeButton"
                                        Grid.Column="1"
                                        Classes="editorButton"
                                        Content="Удалить"
                                        Background="#FFE1DD"
                                        Foreground="#2F2A3A"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#F8FCF5"
                            BorderBrush="#D7E8C8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Сводка"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="SummaryTextBlock"
                                       Text="Вершин: 0 • рёбер: 0"
                                       Foreground="#56624C"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Background="#FBF9F4"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12">
                <DockPanel LastChildFill="True">
    <Border DockPanel.Dock="Top"
            Background="#FFFDF8"
            BorderBrush="#E6DFEE"
            BorderThickness="1"
            CornerRadius="10"
            Padding="8"
            Margin="0,0,0,8">
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="10">

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <TextBlock Text="Подписи"
                           VerticalAlignment="Center"
                           Foreground="#6E6A78"/>
                <ToggleSwitch x:Name="LabelsToggle"
                              IsChecked="True"
                              VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="8">
                <Button x:Name="ZoomOutButton"
                        Content="-"
                        Width="38"
                        Height="32"
                        Background="#D9D5CF"
                        Foreground="#2F2A3A"
                        FontWeight="Bold"/>

                <Button x:Name="ResetZoomButton"
                        Content="Сброс"
                        Height="32"
                        Padding="14,0"
                        Background="#E7E1D8"
                        Foreground="#2F2A3A"/>

                <Button x:Name="ZoomInButton"
                        Content="+"
                        Width="38"
                        Height="32"
                        Background="#D9D5CF"
                        Foreground="#2F2A3A"
                        FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  Background="Transparent">
        <Canvas x:Name="GraphCanvas"
                Background="#FBF9F4"/>
    </ScrollViewer>
</DockPanel>
        
        </Border>

        <Border Grid.ColumnSpan="2"
                Grid.Row="1"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12"
                Margin="0,12,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="10">
                <TextBlock Text="Сохранится итоговый граф: вершины, области и рёбра."
                           Foreground="#6E6A78"
                           VerticalAlignment="Center"/>

                <Button x:Name="CancelButton"
                        Grid.Column="1"
                        Classes="editorButton"
                        Content="Отмена"
                        Background="#E7E1D8"
                        Foreground="#2F2A3A"
                        MinWidth="130"/>

                <Button x:Name="ApplyButton"
                        Grid.Column="2"
                        Classes="editorButton"
                        Content="Сохранить граф"
                        Background="#8E7CC3"
                        Foreground="White"
                        MinWidth="170"/>
            </Grid>
        </Border>
    </Grid>
</Window>