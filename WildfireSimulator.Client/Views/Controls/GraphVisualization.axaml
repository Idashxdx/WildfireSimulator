<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WildfireSimulator.Client.Views.Controls.GraphVisualization">
    <Border Background="#FBF9F4"
            BorderBrush="#E8E1EF"
            BorderThickness="1"
            CornerRadius="12"
            Padding="8">
        <ScrollViewer x:Name="ScrollHost"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="Transparent">
            <Canvas x:Name="GraphCanvas"
                    Background="#FBF9F4"
                    ClipToBounds="True"/>
        </ScrollViewer>
    </Border>
</UserControl>