<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WildfireSimulator.Client.Views.Controls.GraphVisualization">
    <Border Background="#FBF9F4"
            BorderBrush="#E8E1EF"
            BorderThickness="1"
            CornerRadius="12"
            Padding="8">

        <DockPanel LastChildFill="True">

            <Border DockPanel.Dock="Top"
                    Background="#FFFDF8"
                    BorderBrush="#E6DFEE"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="7"
                    Margin="0,0,0,8">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">

                    <TextBlock Grid.Column="0"
                               Text="Визуализация карты"
                               Foreground="#554E63"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">

                        <TextBlock Text="Показать высоту"
                                   VerticalAlignment="Center"
                                   Foreground="#6E6A78" />

                        <ToggleSwitch x:Name="ElevationToggle"
                                      VerticalAlignment="Center" />

                        <Button x:Name="ZoomOutButton"
                                Content="−"
                                Width="30"
                                Height="30"
                                CornerRadius="15"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="#E6E1D8"
                                Foreground="#2F2A3A"
                                FontSize="16"
                                FontWeight="Bold"/>

                        <Button x:Name="ResetZoomButton"
                                Content="Сброс"
                                Height="30"
                                Padding="12,0"
                                CornerRadius="15"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="#EFEAE2"
                                Foreground="#2F2A3A"
                                FontSize="12"
                                FontWeight="SemiBold"/>

                        <Button x:Name="ZoomInButton"
                                Content="+"
                                Width="30"
                                Height="30"
                                CornerRadius="15"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="#E6E1D8"
                                Foreground="#2F2A3A"
                                FontSize="16"
                                FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="#FBF9F4"
                    BorderBrush="#EFE8F7"
                    BorderThickness="1"
                    CornerRadius="10"
                    ClipToBounds="True">
                <ScrollViewer x:Name="ScrollHost"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <Canvas x:Name="GraphCanvas"
                            Background="#FBF9F4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                </ScrollViewer>
            </Border>
        </DockPanel>
    </Border>
</UserControl>