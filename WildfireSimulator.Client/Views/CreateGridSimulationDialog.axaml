<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignWidth="620"
    d:DesignHeight="1000"
    x:Class="WildfireSimulator.Client.Views.CreateGridSimulationDialog"
    Title="Создание сеточной симуляции"
    Width="620"
    Height="1000"
    Background="#FAF8F2"
    CanResize="False">

    <Window.Styles>
        <Style Selector="Button.dialogButton">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.dialogButton:pointerover">
            <Setter Property="Opacity" Value="0.88" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto" Margin="20">
        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="14">

                <TextBlock Text="Создание симуляции"
                           Foreground="#2F2A3A"
                           FontSize="24"
                           FontWeight="Bold" />

                <Border Background="#F5FBFF"
                        BorderBrush="#D7E6F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Демо и случайная карта"
                                   FontWeight="Bold"
                                   Foreground="#2F2A3A" />

                        <TextBlock x:Name="PresetHintTextBlock"
                                   Text="Выберите готовое демо или случайную карту"
                                   Foreground="#6E6A78"
                                   FontSize="12" />

                        <WrapPanel>
                            <Button x:Name="RandomMapButton"
                                    Content="Случайная карта"
                                    Tag="random"
                                    Background="#F1F0EC"
                                    Margin="0,0,8,8" />

                            <Button x:Name="PresetButton1"
                                    Content="Сухой хвойный + ветер"
                                    Tag="dry-coniferous"
                                    Background="#FFE4E1"
                                    Margin="0,0,8,8" />

                            <Button x:Name="PresetButton2"
                                    Content="Река как барьер"
                                    Tag="river"
                                    Background="#E1F0FF"
                                    Margin="0,0,8,8" />

                            <Button x:Name="PresetButton3"
                                    Content="Влажный лес"
                                    Tag="wet"
                                    Background="#E6FFE6"
                                    Margin="0,0,8,8" />

                            <Button x:Name="PresetButton4"
                                    Content="Просека"
                                    Tag="firebreak"
                                    Background="#FFF4E1"
                                    Margin="0,0,8,8" />

                            <Button x:Name="PresetButton5"
                                    Content="Холмы"
                                    Tag="hills"
                                    Background="#F0E6FF"
                                    Margin="0,0,8,8" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Background="#F3F7FF"
                        BorderBrush="#D7E4FF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Тип модели"
                                   Foreground="#6E6A78"
                                   FontSize="12" />
                        <TextBlock x:Name="TypeInfoTextBlock"
                                   Text="Сеточная симуляция"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="TypeHintTextBlock"
                                   Text="Выберите демо, случайную карту или подготовьте итоговую карту вручную."
                                   Foreground="#6E6A78"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="#FFF4F1"
                        BorderBrush="#F1C4BA"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12"
                        IsVisible="False">
                    <TextBlock x:Name="ErrorTextBlock"
                               Text=""
                               Foreground="#B5473E"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Основные параметры"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Название"
                                       Foreground="#6E6A78" />
                            <TextBox x:Name="NameBox"
                                     Text="Сеточная симуляция" />
                            <TextBlock Text="Свободное название симуляции."
                                       Foreground="#8A8793"
                                       FontSize="11" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock x:Name="WidthLabelTextBlock"
                                           Text="Ширина"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="WidthBox"
                                         Text="20" />
                                <TextBlock x:Name="WidthHintTextBlock"
                                           Text="Количество клеток по X • диапазон: 5..200"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock x:Name="HeightLabelTextBlock"
                                           Text="Высота"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="HeightBox"
                                         Text="20" />
                                <TextBlock x:Name="HeightHintTextBlock"
                                           Text="Количество клеток по Y • диапазон: 5..200"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Начальные очаги"
                                       Foreground="#6E6A78" />
                            <TextBox x:Name="FireCellsBox"
                                     Text="3" />
                            <TextBlock x:Name="FireCellsHintTextBlock"
                                       Text="Число очагов при случайном старте • диапазон: 1..50"
                                       Foreground="#8A8793"
                                       FontSize="11" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Количество шагов"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="StepsBox"
                                         Text="100" />
                                <TextBlock Text="Диапазон: 1..10000"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Длительность шага, сек"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="StepDurationBox"
                                         Text="900" />
                                <TextBlock Text="Диапазон: 1..7200"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Параметры среды"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Минимальная влажность"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="MoistureMinBox"
                                         Text="0.30" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Максимальная влажность"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="MoistureMaxBox"
                                         Text="0.70" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Перепад высот"
                                       Foreground="#6E6A78" />
                            <TextBox x:Name="ElevationBox"
                                     Text="50" />
                            <TextBlock Text="Рекомендуемый диапазон: 0..500"
                                       Foreground="#8A8793"
                                       FontSize="11" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Температура воздуха"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="TempBox"
                                         Text="25" />
                                <TextBlock Text="Рекомендуемый диапазон: -50..60"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Влажность воздуха"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="HumidityBox"
                                         Text="40" />
                                <TextBlock Text="Диапазон: 0..100"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Скорость ветра"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="WindSpeedBox"
                                         Text="5" />
                                <TextBlock Text="Рекомендуемый диапазон: 0..40"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Направление ветра"
                                           Foreground="#6E6A78" />
                                <ComboBox x:Name="WindDirBox"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="Север" />
                                    <ComboBoxItem Content="Северо-восток" />
                                    <ComboBoxItem Content="Восток" />
                                    <ComboBoxItem Content="Юго-восток" />
                                    <ComboBoxItem Content="Юг" />
                                    <ComboBoxItem Content="Юго-запад" />
                                    <ComboBoxItem Content="Запад" />
                                    <ComboBoxItem Content="Северо-запад" />
                                </ComboBox>
                                <TextBlock Text="Выберите одно из направлений."
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Осадки"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="PrecipitationBox"
                                         Text="0" />
                                <TextBlock Text="Рекомендуемый диапазон: 0..100"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Случайное зерно"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="RandomSeedBox"
                                         Text="" />
                                <TextBlock Text="Целое число или пусто для случайной генерации."
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Расширенные параметры карты"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Шум карты"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="MapNoiseBox"
                                         Text="0.08" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                                <TextBlock Text="Чем больше значение, тем менее однородной будет карта."
                                           Foreground="#8A8793"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Фактор сухости"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="MapDrynessBox"
                                         Text="1.0" />
                                <TextBlock Text="Рекомендуемый диапазон: 0.5..2.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                                <TextBlock Text="Большее значение делает карту суше и повышает вероятность распространения огня."
                                           Foreground="#8A8793"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Фактор рельефа"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="ReliefStrengthBox"
                                         Text="1.0" />
                                <TextBlock Text="Рекомендуемый диапазон: 0.5..2.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                                <TextBlock Text="Определяет, насколько заметно высоты и низины влияют на форму карты."
                                           Foreground="#8A8793"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Плотность топлива"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="FuelDensityBox"
                                         Text="1.0" />
                                <TextBlock Text="Рекомендуемый диапазон: 0.5..2.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                                <TextBlock Text="Чем больше значение, тем гуще горючий материал на карте."
                                           Foreground="#8A8793"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Структура карты"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <TextBlock x:Name="StructureSummaryTextBlock"
                                   Text="Сводка карты"
                                   Foreground="#2F2A3A"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />

                        <TextBlock x:Name="StructureDetailTextBlock"
                                   Text="Подробности"
                                   Foreground="#6E6A78"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="#FFFDF8"
                        BorderBrush="#E7E0F2"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Вероятности растительности"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Хвойный"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="ConiferousBox"
                                         Text="0.25" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Лиственный"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="DeciduousBox"
                                         Text="0.20" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Смешанный"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="MixedBox"
                                         Text="0.25" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Трава"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="GrassBox"
                                         Text="0.15" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Кустарник"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="ShrubBox"
                                         Text="0.10" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Вода"
                                           Foreground="#6E6A78" />
                                <TextBox x:Name="WaterBox"
                                         Text="0.03" />
                                <TextBlock Text="Диапазон: 0.0..1.0"
                                           Foreground="#8A8793"
                                           FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Пустая поверхность"
                                       Foreground="#6E6A78" />
                            <TextBox x:Name="BareBox"
                                     Text="0.02" />
                            <TextBlock Text="Диапазон: 0.0..1.0"
                                       Foreground="#8A8793"
                                       FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#F7F5FF"
                        BorderBrush="#DDD5F1"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Итоговая карта"
                                   Foreground="#2F2A3A"
                                   FontSize="16"
                                   FontWeight="Bold" />

                        <Border Background="#FFFDF8"
                                BorderBrush="#E7E0F2"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10">
                            <TextBlock x:Name="MapModeDescriptionTextBlock"
                                       Text="Сначала задайте параметры карты, затем при необходимости откройте редактор."
                                       Foreground="#6E6A78"
                                       TextWrapping="Wrap" />
                        </Border>

                        <StackPanel x:Name="ScenarioPanel"
                                    Spacing="8"
                                    IsVisible="False">
                            <TextBlock Text="Описание выбранного демо"
                                       Foreground="#6E6A78" />
                            <Border Background="#FFFDF8"
                                    BorderBrush="#E7E0F2"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <TextBlock x:Name="ScenarioDescriptionTextBlock"
                                           Text="Описание сценария"
                                           Foreground="#6E6A78"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="SemiManualPanel"
                                    Spacing="8"
                                    IsVisible="True">
                            <TextBlock x:Name="SemiManualDescriptionTextBlock"
                                       Text=""
                                       Foreground="#6E6A78"
                                       TextWrapping="Wrap" />

                            <Button x:Name="OpenMapEditorButton"
                                    Classes="dialogButton"
                                    Content="Открыть редактор итоговой карты"
                                    Background="#E8F2E1"
                                    Foreground="#2F2A3A" />

                            <Border Background="#FFFDF8"
                                    BorderBrush="#E7E0F2"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10">
                                <TextBlock x:Name="MapEditorSummaryTextBlock"
                                           Text="Редактор карты ещё не использовался."
                                           Foreground="#6E6A78"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="12"
              Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Grid.Column="0"
                    Classes="dialogButton"
                    Content="Отмена"
                    Background="#ECE6FA"
                    Foreground="#2F2A3A" />

            <Button x:Name="CreateButton"
                    Grid.Column="1"
                    Classes="dialogButton"
                    Content="Создать симуляцию"
                    Background="#CDECBF"
                    Foreground="#2F2A3A" />
        </Grid>
    </Grid>
</Window>