<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="WildfireSimulator.Client.Views.MapEditorDialog"
        Title="Полуручное создание карты"
        Width="1100"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        Background="#FAF8F2">

    <Grid ColumnDefinitions="300,*" RowDefinitions="*,Auto" Margin="16">
        <Border Grid.Column="0"
                Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,12,0">
            <ScrollViewer>
                <StackPanel Spacing="12">
                    <TextBlock Text="Редактор карты"
                               Foreground="#2F2A3A"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <TextBlock Text="Выберите инструмент, форму области и выделите участок мышкой на сетке."
                               Foreground="#6E6A78"
                               TextWrapping="Wrap"/>

                    <Border Background="#F8F5FF"
                            BorderBrush="#E6DFF1"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Инструмент"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>
                            <ComboBox x:Name="ToolBox" SelectedIndex="0">
                                <ComboBoxItem Content="Область хвойного леса"/>
                                <ComboBoxItem Content="Область лиственного леса"/>
                                <ComboBoxItem Content="Область смешанного леса"/>
                                <ComboBoxItem Content="Область травы"/>
                                <ComboBoxItem Content="Область кустарника"/>
                                <ComboBoxItem Content="Водоём"/>
                                <ComboBoxItem Content="Просека"/>
                                <ComboBoxItem Content="Влажная зона"/>
                                <ComboBoxItem Content="Сухая зона"/>
                                <ComboBoxItem Content="Холм"/>
                                <ComboBoxItem Content="Низина"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Background="#F8FCF5"
                            BorderBrush="#D7E8C8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Форма области"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>
                            <ComboBox x:Name="ShapeBox" SelectedIndex="0">
                                <ComboBoxItem Content="Прямоугольник"/>
                                <ComboBoxItem Content="Эллипс"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Background="#F5FBFF"
                            BorderBrush="#D7E6F2"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Сила воздействия"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>
                            <TextBox x:Name="StrengthBox"
                                     Text="1.0"/>
                            <TextBlock Text="Для влажных/сухих зон и рельефа обычно подходит 0.5–1.5."
                                       Foreground="#8A8793"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8EF"
                            BorderBrush="#ECD8B8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Текущее выделение"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="SelectionInfoTextBlock"
                                       Text="Выделение ещё не создано."
                                       Foreground="#6A5A44"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="ObjectsSummaryTextBlock"
                                       Text="Добавленных объектов: 0"
                                       Foreground="#6A5A44"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                x:Name="UndoButton"
                                Content="Отменить последнее"
                                Background="#ECE6FA"
                                Foreground="#2F2A3A"/>
                        <Button Grid.Column="1"
                                x:Name="ClearButton"
                                Content="Очистить всё"
                                Background="#F5E2DE"
                                Foreground="#7A4037"/>
                    </Grid>

                    <Border Background="#FFFDF8"
                            BorderBrush="#E7E0F2"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Легенда"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Тёмно-зелёный — хвойный лес"
                                       Foreground="#4F6B3C"/>
                            <TextBlock Text="Зелёный — лиственный/смешанный лес"
                                       Foreground="#567A48"/>
                            <TextBlock Text="Голубой — вода / влажная зона"
                                       Foreground="#3D6F97"/>
                            <TextBlock Text="Бежевый / серый — сухая зона / просека"
                                       Foreground="#8A6E4D"/>
                            <TextBlock Text="Тёплый коричневый — холм, холодный — низина"
                                       Foreground="#7A5B46"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12">
            <ScrollViewer x:Name="ScrollHost"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="MapCanvas"
                        Background="#FBF9F4"
                        MinWidth="500"
                        MinHeight="500"/>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="1"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,12,0,0">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        x:Name="CancelButton"
                        Content="Отмена"
                        Background="#ECE6FA"
                        Foreground="#2F2A3A"/>
                <Button Grid.Column="1"
                        x:Name="ApplyButton"
                        Content="Сохранить карту"
                        Background="#B7E4A8"
                        Foreground="#2F2A3A"
                        FontWeight="Bold"/>
                <Button Grid.Column="2"
                        x:Name="CloseOnlyButton"
                        Content="Закрыть без сохранения"
                        Background="#F3ECE8"
                        Foreground="#6E6A78"/>
            </Grid>
        </Border>
    </Grid>
</Window>