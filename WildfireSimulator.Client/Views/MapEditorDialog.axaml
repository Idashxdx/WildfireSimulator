<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="WildfireSimulator.Client.Views.MapEditorDialog"
        Title="Редактор итоговой карты"
        Width="1320"
        Height="860"
        MinWidth="1120"
        MinHeight="760"
        Background="#FAF8F2">

    <Window.Styles>
        <Style Selector="Button.editorButton">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.editorButton:pointerover">
            <Setter Property="Opacity" Value="0.88" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="350,*" RowDefinitions="*,Auto" Margin="16">
        <Border Grid.Column="0"
                Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,12,0">
            <ScrollViewer>
                <StackPanel Spacing="12">
                    <TextBlock Text="Редактор карты"
                               Foreground="#2F2A3A"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <TextBlock Text="Выберите клетку на карте, измените её параметры и примените изменения."
                               Foreground="#6E6A78"
                               TextWrapping="Wrap"/>

                    <Border Background="#F8F5FF"
                            BorderBrush="#E6DFF1"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Информация о выборе"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="SelectionInfoTextBlock"
                                       Text="Клетка не выбрана."
                                       Foreground="#6A5A44"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F5FBFF"
                            BorderBrush="#D7E6F2"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Изменение клетки"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Тип поверхности"
                                       Foreground="#6E6A78"/>
                            <ComboBox x:Name="VegetationBox"
                                      SelectedIndex="4">
                                <ComboBoxItem Content="Трава" Tag="Grass"/>
                                <ComboBoxItem Content="Кустарник" Tag="Shrub"/>
                                <ComboBoxItem Content="Лиственный лес" Tag="Deciduous"/>
                                <ComboBoxItem Content="Хвойный лес" Tag="Coniferous"/>
                                <ComboBoxItem Content="Смешанный лес" Tag="Mixed"/>
                                <ComboBoxItem Content="Вода" Tag="Water"/>
                                <ComboBoxItem Content="Пустая поверхность" Tag="Bare"/>
                            </ComboBox>

                            <TextBlock Text="Влажность"
                                       Foreground="#6E6A78"/>
                            <TextBox x:Name="MoistureBox"
                                     Text="0.50"/>

                            <TextBlock Text="Высота"
                                       Foreground="#6E6A78"/>
                            <TextBox x:Name="ElevationBox"
                                     Text="0"/>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="8">
                                <Button x:Name="ApplyToSelectedButton"
                                        Grid.Column="0"
                                        Classes="editorButton"
                                        Content="Применить"
                                        Background="#DDEFD5"
                                        Foreground="#2F2A3A"/>

                                <Button x:Name="ApplyToBrushButton"
                                        Grid.Column="1"
                                        Classes="editorButton"
                                        Content="Кистью"
                                        Background="#ECE6FA"
                                        Foreground="#2F2A3A"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8EF"
                            BorderBrush="#ECD8B8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Кисть"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>

                            <TextBlock Text="Радиус кисти"
                                       Foreground="#6E6A78"/>
                            <ComboBox x:Name="BrushRadiusBox"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="1 клетка" Tag="0"/>
                                <ComboBoxItem Content="3×3" Tag="1"/>
                                <ComboBoxItem Content="5×5" Tag="2"/>
                            </ComboBox>

                            <TextBlock Text="Кисть применяет выбранные параметры вокруг текущей клетки."
                                       Foreground="#8A8793"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFFDF8"
                            BorderBrush="#E7E0F2"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Статистика карты"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="MapSummaryTextBlock"
                                       Text="Сводка карты"
                                       Foreground="#6E6A78"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF4F1"
                            BorderBrush="#F1C4BA"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Подсказка"
                                       Foreground="#2F2A3A"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Один клик выбирает клетку. После изменения параметров нажмите «Применить» или «Кистью»."
                                       Foreground="#6A5A44"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="MapCanvas"
                        Background="#FBF9F4"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.ColumnSpan="2"
              Grid.Row="1"
              ColumnDefinitions="*,*,*"
              ColumnSpacing="12"
              Margin="0,14,0,0">
            <Button x:Name="ResetButton"
                    Grid.Column="0"
                    Classes="editorButton"
                    Content="Сбросить изменения"
                    Background="#F3ECE6"
                    Foreground="#2F2A3A"/>

            <Button x:Name="CancelButton"
                    Grid.Column="1"
                    Classes="editorButton"
                    Content="Отмена"
                    Background="#ECE6FA"
                    Foreground="#2F2A3A"/>

            <Button x:Name="SaveButton"
                    Grid.Column="2"
                    Classes="editorButton"
                    Content="Сохранить карту"
                    Background="#CDECBF"
                    Foreground="#2F2A3A"/>
        </Grid>
    </Grid>
</Window>