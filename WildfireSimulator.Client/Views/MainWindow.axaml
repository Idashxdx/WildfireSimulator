<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:WildfireSimulator.Client.ViewModels"
    xmlns:controls="clr-namespace:WildfireSimulator.Client.Views.Controls"
    xmlns:converters="clr-namespace:WildfireSimulator.Client.Converters"
    mc:Ignorable="d" d:DesignWidth="1500" d:DesignHeight="900"
    x:Class="WildfireSimulator.Client.Views.MainWindow"
    x:DataType="viewModels:MainWindowViewModel"
    Title="Wildfire Simulator - Моделирование лесных пожаров"
    Width="1500"
    Height="900"
    Background="#FAF8F2">

    <Window.Resources>
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter" />
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.uniformButton">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Button.uniformButton:pointerover">
            <Setter Property="Opacity" Value="0.88" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="14">

        <Border Grid.Row="0"
            Background="#FFFDF8"
            BorderBrush="#E7E0F2"
            BorderThickness="1"
            CornerRadius="14"
            Padding="16"
            Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                ColumnSpacing="10">

                <TextBlock Grid.Column="0"
                    Text="Wildfire Simulator"
                    Foreground="#2F2A3A"
                    FontSize="24"
                    FontWeight="Bold"
                    VerticalAlignment="Center" />

                <Border Grid.Column="2"
                    Background="#F6F1FF"
                    BorderBrush="#E1D8F2"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12,8"
                    MinWidth="250"
                    MaxWidth="360"
                    VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                        Foreground="#554E63"
                        FontWeight="SemiBold"
                        TextWrapping="Wrap"
                        VerticalAlignment="Center" />
                </Border>

                <Button Grid.Column="3"
                    Classes="uniformButton"
                    Content="Начать работу"
                    Command="{Binding TestConnectionCommand}"
                    Background="#8E7CC3"
                    Foreground="White"
                    MinWidth="150" />
            </Grid>
        </Border>

        <Grid Grid.Row="1"
            ColumnDefinitions="340,*,330"
            ColumnSpacing="12">

            <Border Grid.Column="0"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14">
                <ScrollViewer>
                    <StackPanel Spacing="14">

                        <TextBlock Text="Навигация"
                            Foreground="#2F2A3A"
                            FontSize="20"
                            FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="8">
                            <Button Grid.Column="0"
                                Classes="uniformButton"
                                Content="Сетка"
                                Command="{Binding SwitchToGridPageCommand}"
                                Background="{Binding IsGridPage, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#DDEFD5;#ECE6FA'}"
                                Foreground="#2F2A3A" />

                            <Button Grid.Column="1"
                                Classes="uniformButton"
                                Content="Графы"
                                Command="{Binding SwitchToGraphPageCommand}"
                                Background="{Binding IsGraphPage, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#DDEFD5;#ECE6FA'}"
                                Foreground="#2F2A3A" />
                        </Grid>

                        <Border Background="#F8F5FF"
                            BorderBrush="#E6DFF1"
                            BorderThickness="1"
                            Padding="10"
                            CornerRadius="10"
                            IsVisible="{Binding IsGraphPage}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Тип создаваемой графовой симуляции"
                                    Foreground="#2F2A3A"
                                    FontSize="14"
                                    FontWeight="Bold" />

                                <StackPanel Spacing="8">
                                    <Button Classes="uniformButton"
                                        Content="Граф"
                                        Command="{Binding SelectClusteredGraphModeCommand}"
                                        Background="{Binding IsClusteredGraphCreationMode, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#DDEFD5;#ECE6FA'}"
                                        Foreground="#2F2A3A" />
                                </StackPanel>

                                <TextBlock
                                    Text="{Binding SelectedGraphCreationModeText, StringFormat=Сейчас будет создано: {0}}"
                                    Foreground="#6E6A78"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="8">
                            <Button Grid.Column="0"
                                Classes="uniformButton"
                                Content="Обновить"
                                Command="{Binding LoadSimulationsCommand}"
                                Background="#ECE6FA"
                                Foreground="#2F2A3A"
                                IsEnabled="{Binding IsConnected}" />

                            <Button Grid.Column="1"
                                Classes="uniformButton"
                                Content="Новая"
                                Command="{Binding CreateSimulationCommand}"
                                Background="#CDECBF"
                                Foreground="#2F2A3A"
                                IsEnabled="{Binding IsConnected}" />
                        </Grid>

                        <TextBlock Text="Сеточные симуляции"
                            Foreground="#2F2A3A"
                            FontSize="18"
                            FontWeight="Bold"
                            IsVisible="{Binding IsGridPage}" />

                        <ListBox ItemsSource="{Binding GridSimulations}"
                            SelectedItem="{Binding SelectedSimulation}"
                            Background="#FBF9F4"
                            Foreground="#2F2A3A"
                            BorderBrush="#E6DFEE"
                            BorderThickness="1"
                            CornerRadius="10"
                            MinHeight="220"
                            IsVisible="{Binding IsGridPage}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4"
                                        Padding="8"
                                        Background="#FFFDF8"
                                        BorderBrush="#EEE7F6"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                FontWeight="Bold"
                                                Foreground="#2F2A3A"
                                                TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding StatusText}"
                                                FontSize="12"
                                                Foreground="#6E6A78"
                                                Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding GraphTypeText}"
                                                FontSize="11"
                                                Foreground="#8E7CC3"
                                                Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Графовые симуляции"
                            Foreground="#2F2A3A"
                            FontSize="18"
                            FontWeight="Bold"
                            IsVisible="{Binding IsGraphPage}" />

                        <ListBox ItemsSource="{Binding GraphSimulations}"
                            SelectedItem="{Binding SelectedSimulation}"
                            Background="#FBF9F4"
                            Foreground="#2F2A3A"
                            BorderBrush="#E6DFEE"
                            BorderThickness="1"
                            CornerRadius="10"
                            MinHeight="220"
                            IsVisible="{Binding IsGraphPage}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4"
                                        Padding="8"
                                        Background="#FFFDF8"
                                        BorderBrush="#EEE7F6"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                FontWeight="Bold"
                                                Foreground="#2F2A3A"
                                                TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding StatusText}"
                                                FontSize="12"
                                                Foreground="#6E6A78"
                                                Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding GraphTypeText}"
                                                FontSize="11"
                                                Foreground="#8E7CC3"
                                                Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Spacing="10"
                            IsVisible="{Binding SelectedSimulation, Converter={StaticResource NullToBoolConverter}}">
                            <TextBlock Text="Управление"
                                Foreground="#2F2A3A"
                                FontSize="18"
                                FontWeight="Bold" />

                            <Border Background="#F8F5FF"
                                BorderBrush="#E6DFF1"
                                BorderThickness="1"
                                Padding="10"
                                CornerRadius="10"
                                IsVisible="{Binding ShowIgnitionControls}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Режим задания очагов"
                                        Foreground="#2F2A3A"
                                        FontSize="14"
                                        FontWeight="Bold" />

                                    <Button Content="Обновить очаги"
                                        Classes="uniformButton"
                                        Command="{Binding RefreshIgnitionSetupCommand}"
                                        Background="#D8E8FF"
                                        Foreground="#2F2A3A"
                                        IsVisible="{Binding CanRefreshIgnitionSetup}"
                                        IsEnabled="{Binding CanRefreshIgnitionSetup}" />

                                    <Grid ColumnDefinitions="*,*"
                                        ColumnSpacing="8">
                                        <Button Grid.Column="0"
                                            Classes="uniformButton"
                                            Content="Случайно"
                                            Command="{Binding SetRandomIgnitionModeCommand}"
                                            Background="{Binding IsRandomIgnitionMode, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#DDEFD5;#ECE6FA'}"
                                            Foreground="#2F2A3A"
                                            IsEnabled="{Binding CanEditIgnitionSetup}" />

                                        <Button Grid.Column="1"
                                            Classes="uniformButton"
                                            Content="Вручную"
                                            Command="{Binding SetManualIgnitionModeCommand}"
                                            Background="{Binding IsManualIgnitionMode, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='#DDEFD5;#ECE6FA'}"
                                            Foreground="#2F2A3A"
                                            IsEnabled="{Binding CanEditIgnitionSetup}" />
                                    </Grid>

                                    <TextBlock
                                        Text="{Binding IgnitionModeText}"
                                        Foreground="#6E6A78"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Text="{Binding IgnitionSelectionSummary}"
                                        Foreground="#8E7CC3"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap"
                                        IsVisible="{Binding CanEditIgnitionSetup}" />

                                    <TextBlock
                                        Text="В ручном режиме выбирайте стартовые клетки или вершины прямо на визуализации."
                                        Foreground="#8B8596"
                                        FontSize="11"
                                        TextWrapping="Wrap"
                                        IsVisible="{Binding IsManualIgnitionMode}" />

                                    <TextBlock
                                        Text="Сейчас на карте показаны сохранённые стартовые очаги. Чтобы задать новые, сначала нажмите «Обновить очаги»."
                                        Foreground="#B26A42"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap"
                                        IsVisible="{Binding CanRefreshIgnitionSetup}" />
                                </StackPanel>
                            </Border>

                            <Separator />

                            <TextBlock Text="Режим запуска"
                                Foreground="#7A7486"
                                FontSize="13"
                                FontWeight="SemiBold" />

                            <Grid ColumnDefinitions="*,*"
                                ColumnSpacing="8">
                                <Button Grid.Column="0"
                                    Classes="uniformButton"
                                    Content="Старт"
                                    Command="{Binding StartSimulationCommand}"
                                    Background="#B7E4A8"
                                    Foreground="#2F2A3A"
                                    IsEnabled="{Binding CanStartSelectedSimulation}" />

                                <Button Grid.Column="1"
                                    Classes="uniformButton"
                                    Content="Шаг"
                                    Command="{Binding ExecuteStepCommand}"
                                    Background="#D8E8FF"
                                    Foreground="#2F2A3A"
                                    IsEnabled="{Binding CanExecuteStepSimulation}" />
                            </Grid>

                            <Separator />

                            <TextBlock Text="Автоматическое выполнение"
                                Foreground="#7A7486"
                                FontSize="13"
                                FontWeight="SemiBold" />

                            <Grid ColumnDefinitions="*,*"
                                RowDefinitions="Auto,Auto"
                                ColumnSpacing="8"
                                RowSpacing="8">

                                <Button Grid.Row="0"
                                    Grid.Column="0"
                                    Classes="uniformButton"
                                    Content="Авто"
                                    Command="{Binding StartAutoSimulationCommand}"
                                    Background="#CDECBF"
                                    Foreground="#2F2A3A"
                                    IsEnabled="{Binding CanStartAutoSimulation}" />

                                <Button Grid.Row="0"
                                    Grid.Column="1"
                                    Classes="uniformButton"
                                    Content="Пауза"
                                    Command="{Binding PauseAutoSimulationCommand}"
                                    Background="#F5D97B"
                                    Foreground="#2F2A3A"
                                    IsEnabled="{Binding CanPauseAutoSimulation}" />

                                <Button Grid.Row="1"
                                    Grid.Column="0"
                                    Classes="uniformButton"
                                    Content="Продолжить"
                                    Command="{Binding ResumeAutoSimulationCommand}"
                                    Background="#D8E8FF"
                                    Foreground="#2F2A3A"
                                    IsEnabled="{Binding CanResumeAutoSimulation}" />

                                <Button Grid.Row="1"
                                    Grid.Column="1"
                                    Classes="uniformButton"
                                    Content="Остановить"
                                    Command="{Binding StopAutoSimulationCommand}"
                                    Background="#EEC8C3"
                                    Foreground="#2F2A3A"
                                    IsEnabled="{Binding CanStopAutoSimulation}" />
                            </Grid>

                            <Border Background="#FFFDF8"
                                BorderBrush="#ECE4F6"
                                BorderThickness="1"
                                Padding="10"
                                CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Автоматическое моделирование"
                                        Foreground="#7A7486"
                                        FontSize="12" />
                                    <TextBlock Text="{Binding AutoSimulationStatusText}"
                                        Foreground="#2F2A3A"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Separator />

                            <TextBlock Text="Служебные действия"
                                Foreground="#7A7486"
                                FontSize="13"
                                FontWeight="SemiBold" />

                            <Grid ColumnDefinitions="*,*"
                                ColumnSpacing="8">
                                <Button Grid.Column="0"
                                    Classes="uniformButton"
                                    Content="Перезапуск"
                                    Command="{Binding ResetSimulationCommand}"
                                    Background="#F5D97B"
                                    Foreground="#2F2A3A"
                                    IsEnabled="{Binding CanResetSimulation}" />

                                <Button Grid.Column="1"
                                    Classes="uniformButton"
                                    Content="Удалить"
                                    Command="{Binding DeleteSimulationCommand}"
                                    Background="#E58A84"
                                    Foreground="White"
                                    IsEnabled="{Binding CanManageSimulationActions}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">

                        <Border Background="#F8F5FF"
                            BorderBrush="#E6DFF1"
                            BorderThickness="1"
                            Padding="12"
                            CornerRadius="10">
                            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto"
                                ColumnSpacing="18">
                                <TextBlock Grid.Column="0"
                                    Text="Визуализация"
                                    Foreground="#2F2A3A"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    VerticalAlignment="Center" />

                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Тип"
                                        FontSize="11"
                                        Foreground="#8A8495" />
                                    <TextBlock Text="{Binding GraphTypeText}"
                                        FontWeight="Bold"
                                        Foreground="#2F2A3A" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="Статус"
                                        FontSize="11"
                                        Foreground="#8A8495" />
                                    <TextBlock Text="{Binding SimulationStatusText}"
                                        FontWeight="Bold"
                                        Foreground="#2F2A3A" />
                                </StackPanel>

                                <StackPanel Grid.Column="3" Spacing="2">
                                    <TextBlock Text="Шаг"
                                        FontSize="11"
                                        Foreground="#8A8495" />
                                    <TextBlock Text="{Binding CurrentStep}"
                                        FontWeight="Bold"
                                        Foreground="#2F2A3A" />
                                </StackPanel>

                                <StackPanel Grid.Column="4" Spacing="2">
                                    <TextBlock Text="Площадь пожара"
                                        FontSize="11"
                                        Foreground="#8A8495" />
                                    <TextBlock Text="{Binding FireArea, StringFormat={}{0:F0} га}"
                                        FontWeight="Bold"
                                        Foreground="#8E7CC3" />
                                </StackPanel>

                                <Button Grid.Column="5"
                                    Classes="uniformButton"
                                    Content="Обновить статус"
                                    Command="{Binding RefreshStatusCommand}"
                                    Background="#ECE6FA"
                                    Foreground="#2F2A3A"
                                    IsEnabled="{Binding IsConnected}"
                                    MinWidth="150" />
                            </Grid>
                        </Border>

                        <Border Background="#F2FAEA"
                            BorderBrush="#D7E8C8"
                            BorderThickness="1"
                            Padding="12"
                            CornerRadius="10">
                            <TextBlock Text="{Binding SimulationInfoText}"
                                Foreground="#2F2A3A"
                                FontWeight="SemiBold"
                                TextWrapping="Wrap" />
                        </Border>

                        <Border Background="#FFFDF8"
                            BorderBrush="#E7E0F2"
                            BorderThickness="1"
                            Padding="12"
                            CornerRadius="12">
                            <Grid MinHeight="560">
                                <controls:GraphVisualization x:Name="GridVisualization"
                                    Cells="{Binding Cells}"
                                    GridWidth="{Binding GridWidth}"
                                    GridHeight="{Binding GridHeight}"
                                    IsIgnitionSelectionEnabled="{Binding IsIgnitionSelectionEnabled}"
                                    IsVisible="{Binding IsGridSelected}" />

                                <controls:NodeGraphVisualization
                                    x:Name="ClusteredGraphVisualization"
                                    Nodes="{Binding GraphNodes}"
                                    Edges="{Binding GraphEdges}"
                                    SelectedNode="{Binding SelectedGraphNode, Mode=TwoWay}"
                                    LayoutHint="{Binding GraphLayoutHint}"
                                    IsIgnitionSelectionEnabled="{Binding IsIgnitionSelectionEnabled}"
                                    IsVisible="{Binding IsClusteredGraphSelected}" />
                            </Grid>
                        </Border>

                        <Border Background="#FFFDF8"
                            BorderBrush="#E7E0F2"
                            BorderThickness="1"
                            Padding="12"
                            CornerRadius="12">
                            <StackPanel Spacing="10">
                                <Border Background="#F6F1FF"
                                    BorderBrush="#E1D8F2"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10,8">
                                    <TextBlock Text="История метрик"
                                        Foreground="#4F4A5E"
                                        FontSize="14"
                                        FontWeight="Bold" />
                                </Border>

                                <TextBlock
                                    Text="{Binding CompactMetricsSummaryText}"
                                    Foreground="#6E6A78"
                                    TextWrapping="Wrap" />

                                <Border Background="#F8F5FF"
                                    BorderBrush="#E6DFF1"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="10">
                                    <Grid ColumnDefinitions="80,120,90,90,90,*"
                                        ColumnSpacing="10">
                                        <TextBlock Grid.Column="0" Text="Шаг" Foreground="#6E6A78"
                                            FontWeight="Bold" />
                                        <TextBlock Grid.Column="1" Text="Площадь"
                                            Foreground="#6E6A78" FontWeight="Bold" />
                                        <TextBlock Grid.Column="2" Text="Горят" Foreground="#6E6A78"
                                            FontWeight="Bold" />
                                        <TextBlock Grid.Column="3" Text="Сгорело"
                                            Foreground="#6E6A78" FontWeight="Bold" />
                                        <TextBlock Grid.Column="4" Text="Скорость"
                                            Foreground="#6E6A78" FontWeight="Bold" />
                                        <TextBlock Grid.Column="5" Text="Затронуто"
                                            Foreground="#6E6A78" FontWeight="Bold" />
                                    </Grid>
                                </Border>

                                <ListBox ItemsSource="{Binding MetricsHistory}"
                                    Background="#FAF8F2"
                                    Foreground="#2F2A3A"
                                    BorderBrush="#ECE4F6"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    MinHeight="220"
                                    MaxHeight="280">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="4"
                                                Padding="10"
                                                Background="#FFFDF8"
                                                BorderBrush="#EEE7F6"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                                <Grid ColumnDefinitions="80,120,90,90,90,*"
                                                    ColumnSpacing="10">
                                                    <TextBlock Grid.Column="0"
                                                        Text="{Binding Step}"
                                                        Foreground="#2F2A3A"
                                                        FontWeight="Bold"
                                                        VerticalAlignment="Center" />

                                                    <TextBlock Grid.Column="1"
                                                        Text="{Binding FireArea, StringFormat={}{0:F0} га}"
                                                        Foreground="#8E7CC3"
                                                        FontWeight="Bold"
                                                        VerticalAlignment="Center" />

                                                    <TextBlock Grid.Column="2"
                                                        Text="{Binding BurningCellsCount}"
                                                        Foreground="#B5473E"
                                                        VerticalAlignment="Center" />

                                                    <TextBlock Grid.Column="3"
                                                        Text="{Binding BurnedCellsCount}"
                                                        Foreground="#6E6A78"
                                                        VerticalAlignment="Center" />

                                                    <TextBlock Grid.Column="4"
                                                        Text="{Binding FireSpreadSpeed, StringFormat={}{0:F2}}"
                                                        Foreground="#2F2A3A"
                                                        VerticalAlignment="Center" />

                                                    <TextBlock Grid.Column="5"
                                                        Text="{Binding TotalCellsAffected}"
                                                        Foreground="#6E6A78"
                                                        VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                Background="#FFFDF8"
                BorderBrush="#E7E0F2"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14">
                <ScrollViewer>
                    <StackPanel Spacing="14">

                        <Expander Header="Легенда"
                            IsExpanded="False">
                            <Border Background="#FFF9DE"
                                BorderBrush="#F0E3A4"
                                BorderThickness="1"
                                Padding="12"
                                CornerRadius="10"
                                Margin="0,8,0,0">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Rectangle Width="20" Height="20" Fill="#FF7A59" RadiusX="4"
                                            RadiusY="4" />
                                        <TextBlock Text="Горит" Foreground="#2F2A3A"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Rectangle Width="20" Height="20" Fill="#777777" RadiusX="4"
                                            RadiusY="4" />
                                        <TextBlock Text="Сгорело" Foreground="#2F2A3A"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Rectangle Width="20" Height="20" Fill="#5E9B5E" RadiusX="4"
                                            RadiusY="4" />
                                        <TextBlock Text="Хвойный лес" Foreground="#2F2A3A"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Rectangle Width="20" Height="20" Fill="#8ACB88" RadiusX="4"
                                            RadiusY="4" />
                                        <TextBlock Text="Лиственный лес" Foreground="#2F2A3A"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Rectangle Width="20" Height="20" Fill="#E7D36F" RadiusX="4"
                                            RadiusY="4" />
                                        <TextBlock Text="Трава" Foreground="#2F2A3A"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Rectangle Width="20" Height="20" Fill="#A8C97F" RadiusX="4"
                                            RadiusY="4" />
                                        <TextBlock Text="Смешанный лес" Foreground="#2F2A3A"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Rectangle Width="20" Height="20" Fill="#CFA46A" RadiusX="4"
                                            RadiusY="4" />
                                        <TextBlock Text="Кустарник" Foreground="#2F2A3A"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Rectangle Width="20" Height="20" Fill="#7CC6F2" RadiusX="4"
                                            RadiusY="4" />
                                        <TextBlock Text="Вода" Foreground="#2F2A3A"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Rectangle Width="20" Height="20" Fill="#C9B7A7" RadiusX="4"
                                            RadiusY="4" />
                                        <TextBlock Text="Пустая поверхность" Foreground="#2F2A3A"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <Expander Header="Параметры"
                            IsExpanded="True">
                            <Border Background="#F2FAEA"
                                BorderBrush="#D7E8C8"
                                BorderThickness="1"
                                Padding="12"
                                CornerRadius="10"
                                Margin="0,8,0,0">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Ветер" Foreground="#7A7486" FontSize="12" />
                                    <TextBlock Text="{Binding WindInfo}" Foreground="#2F2A3A"
                                        FontWeight="SemiBold" />

                                    <TextBlock Text="Температура" Foreground="#7A7486" FontSize="12"
                                        Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding TemperatureInfo}" Foreground="#2F2A3A"
                                        FontWeight="SemiBold" />

                                    <TextBlock Text="Влажность" Foreground="#7A7486" FontSize="12"
                                        Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding HumidityInfo}" Foreground="#2F2A3A"
                                        FontWeight="SemiBold" />

                                    <TextBlock Text="Осадки" Foreground="#7A7486" FontSize="12"
                                        Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding PrecipitationInfo}"
                                        Foreground="#2F2A3A" FontWeight="SemiBold" />

                                    <TextBlock Text="Растительность" Foreground="#7A7486"
                                        FontSize="12" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding VegetationStats}" Foreground="#2F2A3A"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Expander>
                        <Expander Header="Выбранная вершина"
                            IsExpanded="True"
                            IsVisible="{Binding IsGraphPage}">
                            <Border Background="#FFF8F1"
                                BorderBrush="#EFDCC8"
                                BorderThickness="1"
                                Padding="12"
                                CornerRadius="10"
                                Margin="0,8,0,0">
                                <StackPanel Spacing="8">

                                    <Border Background="#FFFDF8"
                                        BorderBrush="#EEE2D3"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding SelectedGraphNodeTitle}"
                                                Foreground="#2F2A3A"
                                                FontSize="15"
                                                FontWeight="Bold" />
                                            <TextBlock Text="{Binding SelectedGraphNodeStateText}"
                                                Foreground="#6E6A78"
                                                FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFFDF8"
                                        BorderBrush="#EEE2D3"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                        <Grid ColumnDefinitions="*,*"
                                            RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                            ColumnSpacing="12"
                                            RowSpacing="8">

                                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Тип поверхности"
                                                    Foreground="#7A7486"
                                                    FontSize="12" />
                                                <TextBlock
                                                    Text="{Binding SelectedGraphNodeVegetationText}"
                                                    Foreground="#2F2A3A"
                                                    FontWeight="SemiBold"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                                <TextBlock
                                                    Text="{Binding SelectedGraphNodeGroupCaption}"
                                                    Foreground="#7A7486"
                                                    FontSize="12" />
                                                <TextBlock
                                                    Text="{Binding SelectedGraphNodeGroupText}"
                                                    Foreground="#2F2A3A"
                                                    FontWeight="SemiBold"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Влажность"
                                                    Foreground="#7A7486"
                                                    FontSize="12" />
                                                <TextBlock
                                                    Text="{Binding SelectedGraphNodeMoistureText}"
                                                    Foreground="#2F2A3A"
                                                    FontWeight="SemiBold" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                                <TextBlock Text="Высота"
                                                    Foreground="#7A7486"
                                                    FontSize="12" />
                                                <TextBlock
                                                    Text="{Binding SelectedGraphNodeElevationText}"
                                                    Foreground="#2F2A3A"
                                                    FontWeight="SemiBold" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Вероятность возгорания"
                                                    Foreground="#7A7486"
                                                    FontSize="12" />
                                                <TextBlock
                                                    Text="{Binding SelectedGraphNodeProbabilityText}"
                                                    Foreground="#2F2A3A"
                                                    FontWeight="SemiBold" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                                                <TextBlock Text="Координаты схемы"
                                                    Foreground="#7A7486"
                                                    FontSize="12" />
                                                <TextBlock
                                                    Text="{Binding SelectedGraphNodeRenderPositionText}"
                                                    Foreground="#2F2A3A"
                                                    FontWeight="SemiBold" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="3" Grid.Column="0"
                                                Grid.ColumnSpan="2" Spacing="2">
                                                <TextBlock Text="Степень и связи"
                                                    Foreground="#7A7486"
                                                    FontSize="12" />
                                                <TextBlock
                                                    Text="{Binding SelectedGraphNodeDegreeSummaryText}"
                                                    Foreground="#2F2A3A"
                                                    FontWeight="SemiBold"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="4" Grid.Column="0"
                                                Grid.ColumnSpan="2" Spacing="2">
                                                <TextBlock Text="Стадия огня"
                                                    Foreground="#7A7486"
                                                    FontSize="12" />
                                                <TextBlock
                                                    Text="{Binding SelectedGraphNodeFireSummaryText}"
                                                    Foreground="#2F2A3A"
                                                    FontWeight="SemiBold"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Background="#FFFDF8"
                                        BorderBrush="#EEE2D3"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Топливо"
                                                Foreground="#7A7486"
                                                FontSize="12" />
                                            <TextBlock
                                                Text="{Binding SelectedGraphNodeFuelSummaryText}"
                                                Foreground="#2F2A3A"
                                                FontWeight="SemiBold"
                                                TextWrapping="Wrap" />

                                            <TextBlock Text="Тепловое состояние"
                                                Foreground="#7A7486"
                                                FontSize="12"
                                                Margin="0,4,0,0" />
                                            <TextBlock
                                                Text="{Binding SelectedGraphNodeThermalSummaryText}"
                                                Foreground="#2F2A3A"
                                                FontWeight="SemiBold"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock
                                        Text="Выберите вершину на графе, чтобы посмотреть её свойства."
                                        Foreground="#8A8495"
                                        FontSize="12"
                                        TextWrapping="Wrap"
                                        IsVisible="{Binding HasNoSelectedGraphNode}" />
                                </StackPanel>
                            </Border>
                        </Expander>

                        <Border Background="#F8F5FF"
                            BorderBrush="#E6DFF1"
                            BorderThickness="1"
                            Padding="12"
                            CornerRadius="10">
                            <StackPanel Spacing="10">

                                <Grid ColumnDefinitions="*,Auto"
                                    ColumnSpacing="8">
                                    <TextBlock Grid.Column="0"
                                        Text="Потоковый анализ"
                                        Foreground="#2F2A3A"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        TextWrapping="Wrap"
                                        VerticalAlignment="Center"
                                        Margin="0,0,6,0" />

                                    <Button Grid.Column="1"
                                        Classes="uniformButton"
                                        Content="Подключить"
                                        Command="{Binding ConnectSignalRCommand}"
                                        Background="#F5D97B"
                                        Foreground="#2F2A3A"
                                        Width="124"
                                        HorizontalAlignment="Right"
                                        IsEnabled="{Binding IsConnected}" />
                                </Grid>

                                <TextBlock Text="{Binding SignalRStatus}"
                                    Foreground="#6E6A78"
                                    FontSize="12" />

                                <Border Background="#FFFDF8"
                                    BorderBrush="#ECE4F6"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Скользящие средние"
                                            Foreground="#7A7486"
                                            FontSize="12" />
                                        <TextBlock Text="{Binding StreamMovingAverageText}"
                                            Foreground="#2F2A3A"
                                            FontWeight="SemiBold"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#FFFDF8"
                                    BorderBrush="#ECE4F6"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Динамика"
                                            Foreground="#7A7486"
                                            FontSize="12" />
                                        <TextBlock Text="{Binding TrendText}"
                                            Foreground="#8E7CC3"
                                            FontWeight="Bold"
                                            TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding StreamDynamicsText}"
                                            Foreground="#2F2A3A"
                                            TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding StreamCriticalText}"
                                            Foreground="#6E6A78"
                                            FontSize="11"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#FFFDF8"
                                    BorderBrush="#ECE4F6"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Прогноз"
                                            Foreground="#7A7486"
                                            FontSize="12" />
                                        <TextBlock Text="{Binding ForecastSummaryText}"
                                            Foreground="#8E7CC3"
                                            FontWeight="Bold"
                                            TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ForecastErrorSummaryText}"
                                            Foreground="#6E6A78"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#FFFDF8"
                                    BorderBrush="#ECE4F6"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Аномалия"
                                            Foreground="#7A7486"
                                            FontSize="12" />
                                        <TextBlock Text="{Binding LastAnomalyText}"
                                            Foreground="#2F2A3A"
                                            FontWeight="SemiBold"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#FFFDF8"
                            BorderBrush="#E7E0F2"
                            BorderThickness="1"
                            Padding="12"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="Лог событий"
                                    Foreground="#2F2A3A"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Margin="0,0,0,8" />

                                <ListBox ItemsSource="{Binding EventLog}"
                                    Background="#FAF8F2"
                                    Foreground="#6E6A78"
                                    BorderBrush="#ECE4F6"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MinHeight="220">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                FontSize="11"
                                                Margin="8,6"
                                                TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>