{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning",
      "WildfireSimulator": "Information",
      "WildfireSimulator.Application.Services": "Debug",
      "WildfireSimulator.Infrastructure.Kafka": "Debug"
    },
    "Console": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft": "Warning",
        "WildfireSimulator": "Information"
      },
      "FormatterName": "json",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "HH:mm:ss ",
        "UseUtcTimestamp": false,
        "JsonWriterOptions": {
          "Indented": false
        }
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=wildfire_db;Username=wildfire_user;Password=wildfire_pass"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "wildfire-simulator-group",
    "TopicConfig": {
      "FireEvents": "fire-events",
      "Metrics": "fire-metrics",
      "SimulationCommands": "simulation-commands"
    }
  }
}
